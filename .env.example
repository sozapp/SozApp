EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_REVENUECAT_KEY=
# Sentry crash/error reporting — kendi Sentry hesabınızdan alın (sentry.io > Settings > Projects > Client Keys/DSN).
# Boş bırakılırsa initSentry() hiçbir şey yapmaz (crash reporting devre dışı kalır).
# Not: Sadece EAS build / development build'de çalışır — Expo Go'da native modül bulunmadığı için etkisizdir.
EXPO_PUBLIC_SENTRY_DSN=

# Ürün analitiği (PostHog) — posthog.com'da EU Cloud region ile proje açın,
# Project Settings > Project API Key'den alın. Boş bırakılırsa initAnalytics()
# hiçbir şey yapmaz (analitik devre dışı kalır). Host'u değiştirmezseniz
# varsayılan EU Cloud (https://eu.i.posthog.com) kullanılır.
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Supabase Edge Function secrets (supabase secrets set — client'a koymayın):
# GROQ_API_KEY=
# REVENUECAT_WEBHOOK_SECRET=
